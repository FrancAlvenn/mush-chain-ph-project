		"userdoc": {
			"kind": "user",
			"methods": {
				"confirmDelivery(uint256,uint256,uint8,string)": {
					"notice": "Vendor confirms receipt of the batch, closing the chain of custody.         This is the final, immutable event for this batch on the blockchain."
				},
				"deactivateParticipant(address)": {
					"notice": "Admin can deactivate a participant (e.g., revoke accreditation)."
				},
				"getAllBatches()": {
					"notice": "Returns all batch IDs ever registered on this contract."
				},
				"getAuditEntry(uint256)": {
					"notice": "Returns a single audit log entry by its entry ID.         Use this if you want to inspect one specific event."
				},
				"getAuditReport(uint256)": {
					"notice": "Returns a fully formatted, human-readable audit report string         for a batch — all events concatenated into one readable block.         Great for a quick copy-paste summary or presentation demo.         Example output for a completed batch:         \"         [1] BATCH_REGISTERED | Role: Farmer | Actor: 0xAB..cd              Farm: Dela Cruz Mushroom Farm | Variety: Oyster | Qty: 50 kg | ...              Time: 1746000000         ──────────────────────────────────────────         [2] OWNERSHIP_TRANSFERRED | Role: Farmer | Actor: 0xAB..cd              From Farmer: 0xAB..cd -> Trader: 0xCD..ef | Price/kg: 85 | ...              Time: 1746000060         ...\""
				},
				"getBatchAuditTrail(uint256)": {
					"notice": "Returns the FULL audit trail for a batch in a single call.         Every field of every audit entry is returned as parallel arrays —         index [0] = first event, index [1] = second event, etc.         In Remix, the decoded output will show 6 labeled arrays:           entryIds   — the internal audit entry IDs           actions    — e.g. \"BATCH_REGISTERED\", \"OWNERSHIP_TRANSFERRED\"           actors     — wallet address of who performed each action           actorRoles — \"Farmer\", \"Trader\", \"Transporter\", \"Vendor\"           details    — full human-readable description of what happened           timestamps — unix timestamp of each event         You can read all 4 supply chain events for a batch at once,         with no need to call getAuditEntry() separately."
				},
				"getBatchStatus(uint256)": {
					"notice": "Returns the current status of a batch as a human-readable label."
				},
				"getDeliveryRecord(uint256)": {
					"notice": "Returns the delivery confirmation for a batch."
				},
				"getParticipant(address)": {
					"notice": "Returns a participant's profile."
				},
				"getProvenance(uint256)": {
					"notice": "Returns the full provenance summary of a batch.         Simulates what a consumer would see after scanning the QR code."
				},
				"getShipmentRecord(uint256)": {
					"notice": "Returns the shipment record for a batch."
				},
				"getTransferRecord(uint256)": {
					"notice": "Returns the ownership transfer record for a batch."
				},
				"logShipment(uint256,string,string,string,uint256,string)": {
					"notice": "Transporter logs pickup and shipment of a batch.         The Trader (current owner) must have handed off to the Transporter.         In this prototype, the Transporter calls this function directly         once they have physically received the batch from the Trader."
				},
				"reactivateParticipant(address)": {
					"notice": "Admin can reactivate a participant."
				},
				"registerBatch(uint8,uint256,string,string,string,string)": {
					"notice": "Farmer registers a harvested mushroom batch.         This mints a \"product token\" on the blockchain."
				},
				"registerParticipant(address,string,uint8,string,string,string)": {
					"notice": "Admin registers a supply chain participant and assigns their role."
				},
				"transferToTrader(uint256,address,uint256,string)": {
					"notice": "Farmer sells and transfers a batch to a registered Trader.         Caller must be the current owner (Farmer at this stage)."
				}
			},
			"notice": "============================================================  MushChain PH — Farm-to-Market Traceability Smart Contract  Dr. Yanga's Colleges, Inc. (DYCI)  Prepared by: Patricia Mae Polintan & Franc Alvenn Dela Cruz ============================================================  HOW TO USE IN REMIX IDE:  ─────────────────────────────────────────────────────────  1. Paste this file into Remix (remix.ethereum.org)  2. Compile with Solidity ^0.8.20  3. Deploy using \"JavaScript VM (London)\" — no wallet needed  4. Remix gives you multiple test accounts. Assign them:       Account[0] → Admin       (deploy from this account)       Account[1] → Farmer       Account[2] → Trader       Account[3] → Transporter       Account[4] → Vendor  5. Follow the STEP-BY-STEP SIMULATION GUIDE at the bottom. ============================================================",
			"version": 1
		}
	},
